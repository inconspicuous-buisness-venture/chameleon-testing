@prefix ex: <http://example.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:Root a ex:Path ;
    ex:coherenceDifference 0 ;
    ex:coherenceScore 0e+00 ;
    ex:next ex:Token_1_0,
        ex:Token_1_1,
        ex:Token_1_2,
        ex:Token_2_0,
        ex:Token_2_1,
        ex:Token_2_2,
        ex:Token_3_0,
        ex:Token_3_1,
        ex:Token_3_2 ;
    ex:text "Once upon a time" .

ex:Token_1_0 a ex:Token ;
    ex:coherenceScore 0e+00 ;
    ex:iteration 1 ;
    ex:text "," .

ex:Token_1_1 a ex:Token ;
    ex:coherenceScore 0e+00 ;
    ex:iteration 1 ;
    ex:text "there" .

ex:Token_1_2 a ex:Token ;
    ex:coherenceScore 0e+00 ;
    ex:iteration 1 ;
    ex:text "in" .

ex:Token_2_0 a ex:Token ;
    ex:coherenceScore 0e+00 ;
    ex:iteration 2 ;
    ex:text "," .

ex:Token_2_1 a ex:Token ;
    ex:coherenceScore 0e+00 ;
    ex:iteration 2 ;
    ex:text "there" .

ex:Token_2_2 a ex:Token ;
    ex:coherenceScore 0e+00 ;
    ex:iteration 2 ;
    ex:text "in" .

ex:Token_3_0 a ex:Token ;
    ex:coherenceScore 0e+00 ;
    ex:iteration 3 ;
    ex:text "," .

ex:Token_3_1 a ex:Token ;
    ex:coherenceScore 0e+00 ;
    ex:iteration 3 ;
    ex:text "there" .

ex:Token_3_2 a ex:Token ;
    ex:coherenceScore 0e+00 ;
    ex:iteration 3 ;
    ex:text "in" .

